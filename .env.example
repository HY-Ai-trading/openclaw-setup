# 키움증권 API 서버 주소
TRADING_SERVER_URL=https://your-api-server.example.com

# API 서버 인증 시크릿 키 (서버 측 SIGNAL_SECRET_KEY와 동일한 값)
SIGNAL_SECRET_KEY=your_64char_hex_secret_key_here

# Discord Bot 토큰 (Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord 알림 수신자 ID (Discord 사용자 ID, 개발자 모드에서 우클릭 복사)
DISCORD_USER_ID=your_discord_user_id_here

# 대시보드 비밀번호 (API 서버 대시보드 접근용)
DASHBOARD_PASSWORD=your_dashboard_password

# 세션 시크릿 (임의의 긴 랜덤 문자열)
SESSION_SECRET=your_64char_hex_session_secret_here

# DART 공시 API 키 (https://opendart.fss.or.kr 에서 발급)
DART_API_KEY=your_dart_api_key_here
